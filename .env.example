APP_ENV=local
LOG_LEVEL=info

NGINX_PORT=8080

API_GATEWAY_PORT=8081
ORDER_SERVICE_PORT=8082
TRACKING_SERVICE_PORT=8083
CARRIER_SYNC_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085

ORDER_SERVICE_URL=http://order-service:8082
TRACKING_SERVICE_URL=http://tracking-service:8083
CARRIER_SYNC_SERVICE_URL=http://carrier-sync-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085
UPSTREAM_REQUEST_TIMEOUT=10s
NOTIFICATION_REQUEST_TIMEOUT=3s
NOTIFICATION_EMAIL_RECIPIENT=user@example.com
NOTIFICATION_TELEGRAM_RECIPIENT=@trackflow_user

POSTGRES_DSN=postgres://trackflow:trackflow@postgres:5432/trackflow?sslmode=disable
REDIS_ADDR=redis:6379
ORDER_CACHE_TTL=1m

CARRIER_API_BASE_URL=https://carrier.example/api
CARRIER_API_TOKEN=replace-me
CARRIER_REQUEST_TIMEOUT=5s
TRACKING_REQUEST_TIMEOUT=5s
NOTIFICATION_PROVIDER=mock
NOTIFICATION_API_KEY=replace-me
NOTIFICATION_DEDUP_WINDOW=24h
